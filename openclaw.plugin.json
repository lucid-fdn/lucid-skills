{
  "id": "lucid-compete",
  "name": "Lucid Compete",
  "version": "1.0.0",
  "description": "Competitive intelligence monitoring, AI battle cards, and real-time alerts",
  "author": "RaijinLabs",
  "configSchema": {
    "type": "object",
    "properties": {
      "supabaseUrl": { "type": "string", "description": "Supabase project URL" },
      "supabaseKey": { "type": "string", "description": "Supabase service role key" },
      "tenantId": { "type": "string", "default": "default", "description": "Tenant ID for multi-tenancy" },
      "fetchSchedule": { "type": "string", "default": "0 */6 * * *", "description": "Cron schedule for fetching monitors" },
      "briefSchedule": { "type": "string", "default": "0 9 * * 1", "description": "Cron schedule for generating weekly briefs" },
      "githubToken": { "type": "string", "description": "GitHub personal access token" },
      "twitterBearerToken": { "type": "string", "description": "Twitter/X API bearer token" },
      "slackWebhookUrl": { "type": "string", "description": "Slack incoming webhook URL for alerts" },
      "alertWebhookUrl": { "type": "string", "description": "Generic webhook URL for alerts" },
      "alertEmail": { "type": "string", "description": "Email address for critical alerts" },
      "smtpHost": { "type": "string", "description": "SMTP host for email alerts" },
      "smtpPort": { "type": "number", "description": "SMTP port" },
      "smtpUser": { "type": "string", "description": "SMTP username" },
      "smtpPass": { "type": "string", "description": "SMTP password" },
      "alertSeverity": { "type": "string", "enum": ["low", "medium", "high", "critical"], "default": "high", "description": "Minimum severity to trigger alerts" }
    },
    "required": ["supabaseUrl", "supabaseKey"]
  },
  "uiHints": {
    "category": "competitive-intelligence",
    "icon": "shield",
    "color": "#FF6B35"
  }
}
