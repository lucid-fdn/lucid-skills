{
  "name": "@lucid-fdn/audit",
  "version": "2.0.0",
  "description": "Lucid Audit — Smart Contract Security MCP: AI brain layer with verdicts, vulnerability detection, gas optimization, access control review, and security scoring",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "audit-mcp": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "smart-contract",
    "security",
    "audit",
    "vulnerability",
    "solidity",
    "defi",
    "mcp",
    "ethereum",
    "web3"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
