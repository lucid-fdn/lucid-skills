{
  "name": "@raijinlabs/recruit",
  "version": "1.0.0",
  "description": "Lucid Recruit — AI-powered ATS & hiring pipeline MCP plugin",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "recruit-mcp": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "ats",
    "hiring",
    "recruiting",
    "candidates",
    "jobs",
    "talent",
    "hr",
    "mcp",
    "lucid"
  ],
  "author": "RaijinLabs",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sinclair/typebox": "^0.34.33",
    "@supabase/supabase-js": "^2.49.4",
    "bottleneck": "^2.19.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
