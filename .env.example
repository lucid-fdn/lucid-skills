# Supabase (required)
COMPETE_SUPABASE_URL=
COMPETE_SUPABASE_KEY=

# Tenant
COMPETE_TENANT_ID=default

# Schedules
COMPETE_FETCH_SCHEDULE=0 */6 * * *
COMPETE_BRIEF_SCHEDULE=0 9 * * 1

# GitHub (optional, for higher rate limits)
COMPETE_GITHUB_TOKEN=

# Twitter/X (optional)
COMPETE_TWITTER_BEARER_TOKEN=

# Alerts — Slack (optional)
COMPETE_SLACK_WEBHOOK_URL=

# Alerts — Webhook (optional)
COMPETE_ALERT_WEBHOOK_URL=

# Alerts — Email (optional)
COMPETE_ALERT_EMAIL=
COMPETE_SMTP_HOST=
COMPETE_SMTP_PORT=
COMPETE_SMTP_USER=
COMPETE_SMTP_PASS=

# Alert severity threshold (default: high)
COMPETE_ALERT_SEVERITY=high
